# Environment Variables
PORT=3000

# Redis (local in-memory)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Optional
NODE_ENV=production
LOG_LEVEL=info

# Railway will auto-provide PORT in production
